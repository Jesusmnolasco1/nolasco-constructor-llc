# Build Base Path
# ================
#
# VITE_BASE_PATH:
#   Set to "/" for Vercel or custom domain (default).
#   Set to "/nolasco-constructor-llc/" for GitHub Pages project site.
#
#   GitHub Pages: VITE_BASE_PATH=/nolasco-constructor-llc/ npm run build
#   Vercel:       (not needed — defaults to "/")
#
#   This variable is NOT exposed to the browser. It is used during the build
#   by vite.config.js.

VITE_BASE_PATH=/

# Contact Form Configuration
# ==========================
#
# VITE_CONTACT_FORM_MODE:
#   Use "demo" during development. Use "external" only when a valid form
#   endpoint is configured. Any variable prefixed with VITE_ is exposed to the
#   browser build, so it must NOT contain secrets.
#
# VITE_CONTACT_FORM_ENDPOINT:
#   The full URL to a static form submission endpoint that accepts JSON POST.
#   The endpoint must not require private secrets in frontend code.

VITE_CONTACT_FORM_MODE=demo
VITE_CONTACT_FORM_ENDPOINT=
