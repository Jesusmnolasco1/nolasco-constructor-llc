# Build Base Path
# ================
#
# VITE_BASE_PATH:
#   Set to "/" for Vercel or custom domain (default).
#   Set to "/nolasco-constructor-llc/" for GitHub Pages project site.
#
#   GitHub Pages: VITE_BASE_PATH=/nolasco-constructor-llc/ npm run build
#   Vercel:       (not needed — defaults to "/")
#
#   This variable is NOT exposed to the browser. It is used during the build
#   by vite.config.js.

VITE_BASE_PATH=/

# Contact Form Configuration
# ==========================
#
# VITE_CONTACT_FORM_MODE:
#   "internal" — send to the Vercel Serverless Function at /api/contact
#                (default for production).
#   "demo"     — validate locally only, no data sent anywhere (for development).
#
#   Any variable prefixed with VITE_ is exposed to the browser, so it must
#   NOT contain secrets.

VITE_CONTACT_FORM_MODE=internal

# Supabase (server-side only — Vercel Serverless Function)
# =========================================================
#
# These variables are used by the Vercel Function at api/contact.js.
# They are NEVER exposed to the browser.
# Do NOT prefix them with VITE_.
# Do NOT add them to .env (only to Vercel environment variables).
#
# SUPABASE_URL:
#   Your Supabase project URL (e.g. https://xxxxx.supabase.co)
#
# SUPABASE_SERVICE_ROLE_KEY:
#   Your Supabase service_role key (secret — never expose in frontend code).
#   This key bypasses Row Level Security and must stay server-side only.

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
